# --- Supabase ---
supabase/.temp/
supabase/.branches/

# --- IDE ---
.idea/
*.iml
*.iws
*.ipr
.vscode/
.settings/
.project
.classpath
.factorypath
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Env & Secrets ---
.env
.env.*
!.env.example